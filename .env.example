# Supabase (required)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres connection for schema init (npm run init:schema)
SUPABASE_POSTGRES_CONNECTION_STRING=

# Firebase Admin (required for /api auth)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Or point to a downloaded service account JSON instead of the three vars above:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Optional backend settings
PORT=4000
NODE_ENV=development
CLIENT_BASE_URL=http://localhost:8080
JWT_SECRET=replace-with-strong-secret
